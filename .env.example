# Google Gemini API Configuration (Server-Side)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Database Configuration (Client-Side / Frontend)
# Note: Since this is a React Vite SPA, client-side variables must be prefixed with VITE_
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key_here

# Vapi API Configuration (Client-Side)
VITE_VAPI_PUBLIC_KEY=your_vapi_public_key_here
VITE_VAPI_ASSISTANT_ID=your_vapi_assistant_id_here
